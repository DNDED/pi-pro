{
  "name": "promyra",
  "version": "0.1.0",
  "description": "Improved coding agent on top of pi-mono",
  "type": "module",
  "bin": {
    "promyra": "./bin/promyra"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@promyra/skill-bundle": "workspace:*",
    "@promyra/checkpoint": "workspace:*",
    "@promyra/memory": "workspace:*",
    "@promyra/tasks": "workspace:*",
    "@promyra/subagent": "workspace:*",
    "@promyra/tui-pro": "workspace:*",
    "@promyra/provider": "workspace:*",
    "@promyra/tools": "workspace:*",
    "@promyra/bench": "workspace:*",
    "commander": "^12.0.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
